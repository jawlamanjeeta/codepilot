{
  "name": "codepilot",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @codepilot/db db:generate",
    "db:migrate": "pnpm --filter @codepilot/db db:migrate",
    "db:push": "pnpm --filter @codepilot/db db:push",
    "db:studio": "pnpm --filter @codepilot/db db:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.0.14",
    "typescript": "^5.5.4"
  }
}